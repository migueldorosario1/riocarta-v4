---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import destaques from '../data/destaques.json';
import { sortPostsWithSticky } from '../utils/stickyPosts';

const posts = sortPostsWithSticky((await getCollection('blog')).filter((post) => !post.data.draft));
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
			}
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: calc(50% - 1rem);
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li:first-child {
				width: 100%;
				margin-bottom: 1rem;
				text-align: center;
			}
			ul li:first-child img {
				width: 100%;
			}
			ul li:first-child .title {
				font-size: 2.369rem;
			}
			ul li img {
				margin-bottom: 0.5rem;
				border-radius: 12px;
			}
			ul li a {
				display: block;
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
				line-height: 1;
			}
			.date {
				margin: 0;
				color: rgb(var(--gray));
			}
			ul li a:hover h4,
			ul li a:hover .date {
				color: rgb(var(--accent));
			}
			ul a:hover img {
				box-shadow: var(--box-shadow);
			}
			@media (max-width: 720px) {
				ul {
					gap: 0.5em;
				}
				ul li {
					width: 100%;
					text-align: center;
				}
				ul li:first-child {
					margin-bottom: 0;
				}
				ul li:first-child .title {
					font-size: 1.563em;
				}
			}


			/* === Destaques (v2 polida) === */
			.featured-voices { margin-bottom: 3rem; }
			.fv-grid {
				display: grid;
				grid-template-columns: repeat(4, 1fr);
				gap: 1.5rem;
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.fv-grid li:first-child { grid-column: span 4; }
			.fv-card {
				display: flex;
				flex-direction: column;
				height: 100%;
				border: 1px solid rgba(var(--gray), 0.25);
				border-radius: 14px;
				overflow: hidden;
				background: #ffffff;
				transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
			}
			.fv-link:hover .fv-card {
				transform: translateY(-4px);
				box-shadow: 0 12px 32px rgba(0,0,0,0.18);
				border-color: rgb(var(--accent));
			}
			.fv-grid li:first-child .fv-card { flex-direction: row; min-height: 280px; }
			.fv-img { width: 100%; aspect-ratio: 16/9; object-fit: cover; display: block; }
			.fv-grid li:first-child .fv-img { width: 52%; aspect-ratio: auto; }
			.fv-content {
				padding: 1.1rem 1.25rem 1.3rem;
				display: flex;
				flex-direction: column;
				gap: 0.55rem;
				justify-content: center;
			}
			.fv-grid li:first-child .fv-content { padding: 2.25rem; }
			.fv-kicker {
				display: inline-block;
				font-size: 0.68rem;
				font-weight: 800;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				color: rgb(var(--accent));
				border: 1px solid rgb(var(--accent));
				border-radius: 999px;
				padding: 0.18rem 0.7rem;
				width: fit-content;
			}
			.fv-title {
				font-size: 1.08rem;
				font-weight: 700;
				line-height: 1.28;
				margin: 0;
				color: rgb(var(--black));
			}
			.fv-grid li:first-child .fv-title { font-size: 1.7rem; letter-spacing: -0.01em; }
			.fv-desc {
				font-size: 0.87rem;
				color: rgb(var(--gray));
				margin: 0;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}
			.fv-link { text-decoration: none; display: block; height: 100%; }
			.fv-link:hover .fv-title { color: rgb(var(--accent)); }
			@media (max-width: 900px) {
				.fv-grid { grid-template-columns: repeat(2, 1fr); }
				.fv-grid li:first-child { grid-column: span 2; }
			}
			@media (max-width: 560px) {
				.fv-grid { grid-template-columns: 1fr; }
				.fv-grid li:first-child { grid-column: span 1; }
				.fv-grid li:first-child .fv-card { flex-direction: column; }
				.fv-grid li:first-child .fv-img { width: 100%; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="featured-voices">
				<h2 class="fv-section-title">Destaques do Rio</h2>
				<ul class="fv-grid">
					{
						destaques.map((d) => (
							<li>
								<a href={d.url} class="fv-card">
									{d.hero && <img class="fv-img" src={d.hero} alt={d.title} loading="lazy" />}
									<div class="fv-content">
										<span class="fv-kicker">{d.kicker}</span>
										<h3 class="fv-title">{d.title}</h3>
										<p class="fv-desc">{d.description}</p>
									</div>
								</a>
							</li>
						))
					}
				</ul>
			</section>
			<section>
				<ul id="news-list">
					{
						posts.slice(0, 100).map((post, index) => (
							<li class="news-item" style={index >= 20 ? 'display: none;' : ''}>
								<a href={`/blog/${post.id}/`}>
									{post.data.heroImage && (
										<img width="720" height="360" src={post.data.heroImage} alt="" loading={index >= 20 ? "lazy" : "eager"} />
									)}
									<h4 class="title">{post.data.title}</h4>
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</a>
							</li>
						))
					}
				</ul>
				<div style="text-align: center; margin-top: 3rem; margin-bottom: 2rem;">
					<button id="ver-mais-btn" style="padding: 0.8rem 2rem; background: #333; color: white; border: none; cursor: pointer; border-radius: 8px; font-weight: bold; margin-bottom: 1rem; transition: background 0.2s;">Ver mais notícias</button>
					<br/>
					<a id="ver-historico-btn" href="/historico" style="display: none; padding: 0.8rem 2rem; background: #0052D4; color: white; border-radius: 8px; font-weight: bold; text-decoration: none; transition: background 0.2s;">Ir para o Arquivo Histórico</a>
				</div>
				<script>
					let currentShown = 20;
					const items = document.querySelectorAll('.news-item');
					const btnVerMais = document.getElementById('ver-mais-btn');
					const btnVerHistorico = document.getElementById('ver-historico-btn');
					
					if (items.length <= 20) {
						if(btnVerMais) btnVerMais.style.display = 'none';
						if(btnVerHistorico) btnVerHistorico.style.display = 'inline-block';
					}

					if(btnVerMais) {
						btnVerMais.addEventListener('click', () => {
							for (let i = currentShown; i < currentShown + 20 && i < items.length; i++) {
								items[i].style.display = '';
							}
							currentShown += 20;
							if (currentShown >= items.length) {
								btnVerMais.style.display = 'none';
								if(btnVerHistorico) btnVerHistorico.style.display = 'inline-block';
							}
						});
					}
				</script>
			</section>
		</main>
		<Footer />
	</body>
</html>
