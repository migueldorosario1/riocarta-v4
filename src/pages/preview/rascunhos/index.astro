---
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import FormattedDate from '../../../components/FormattedDate.astro';
import Header from '../../../components/Header.astro';

const drafts = (await getCollection('blog'))
	.filter((post) => post.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<BaseHead title="Previa de rascunhos - Rio Carta" description="Previa local de rascunhos do Rio Carta" />
		<meta name="robots" content="noindex,nofollow" />
		<style>
			main {
				width: 960px;
				max-width: 100%;
				margin: 0 auto;
				padding: 2rem 1rem;
			}
			h1 {
				margin-bottom: 0.25rem;
			}
			.preview-note {
				margin: 0 0 2rem;
				color: rgb(var(--gray));
			}
			.drafts {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
				gap: 1.25rem;
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.draft {
				border: 1px solid rgba(var(--gray), 0.25);
				border-radius: 8px;
				overflow: hidden;
				background: white;
			}
			.draft a {
				display: block;
				color: inherit;
				text-decoration: none;
			}
			.draft img {
				width: 100%;
				aspect-ratio: 16 / 9;
				object-fit: cover;
				display: block;
			}
			.draft-body {
				padding: 1rem;
			}
			.draft h2 {
				margin: 0 0 0.5rem;
				font-size: 1.15rem;
				line-height: 1.2;
			}
			.draft p {
				margin: 0.4rem 0;
				color: rgb(var(--gray));
			}
			.tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.35rem;
				margin-top: 0.75rem;
			}
			.tag {
				border: 1px solid rgba(var(--gray), 0.35);
				border-radius: 999px;
				padding: 0.15rem 0.45rem;
				font-size: 0.78rem;
				color: rgb(var(--gray));
			}
			.empty {
				padding: 2rem;
				border: 1px solid rgba(var(--gray), 0.25);
				border-radius: 8px;
				color: rgb(var(--gray));
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>Previa de rascunhos</h1>
			<p class="preview-note">Area local para revisar rascunhos antes de qualquer publicacao.</p>
			{
				drafts.length > 0 ? (
					<ul class="drafts">
						{drafts.map((post) => (
							<li class="draft">
								<a href={`/preview/rascunhos/${post.id}/`}>
									{post.data.heroImage && <img src={post.data.heroImage} alt="" />}
									<div class="draft-body">
										<h2>{post.data.title}</h2>
										<p><FormattedDate date={post.data.pubDate} /></p>
										<p>{post.data.description}</p>
										{post.data.tags && (
											<div class="tags">
												{post.data.tags.slice(0, 8).map((tag) => <span class="tag">{tag}</span>)}
											</div>
										)}
									</div>
								</a>
							</li>
						))}
					</ul>
				) : (
					<div class="empty">Nenhum rascunho encontrado.</div>
				)
			}
		</main>
		<Footer />
	</body>
</html>
