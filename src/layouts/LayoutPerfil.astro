---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

type Props = {
	title: string;
	description?: string;
	pubDate?: Date;
	heroImage?: string;
	noindex?: boolean;
};

const { title, description = title, pubDate = new Date(), heroImage, noindex = false } = Astro.props;
---

<html lang="pt-BR">
	<head>
		<BaseHead title={title} description={description} image={heroImage} />
		{noindex && <meta name="robots" content="noindex,nofollow" />}
		<style>
			main {
				width: 100% !important;
				max-width: 960px !important;
				margin: 0 auto !important;
				padding: 2rem 1.5rem;
				box-sizing: border-box;
				text-align: left;
			}
			.profile-header {
				background: #f7f9fc;
				border: 1px solid #e6eaf0;
				border-radius: 20px;
				padding: 3rem 2rem;
				margin-bottom: 2rem;
				text-align: center;
				box-sizing: border-box;
			}
			.profile-header h1 {
				font-size: 2.5rem;
				margin: 0 0 0.5rem 0;
			}
			.profile-header .meta {
				color: #666;
				font-size: 1.1rem;
			}
			.prose {
				max-width: 720px;
				margin: 0 auto;
				padding: 0 1rem;
				color: #333;
				line-height: 1.8;
				text-align: left;
				box-sizing: border-box;
			}
			@media (max-width: 720px) {
				main { padding: 1rem; }
				.profile-header { padding: 2rem 1rem; border-radius: 0; }
				.profile-header h1 { font-size: 1.8rem; }
				.prose { padding: 0 0.5rem; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="profile-header">
				<h1>{title}</h1>
				<div class="meta">
					<slot name="meta" />
				</div>
			</div>
			<div class="prose">
				<slot />
			</div>
		</main>
		<Footer />
	</body>
</html>
