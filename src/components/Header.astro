			display: none;
		}
		.nav-item {
			position: static;
		}
		.dropdown-content {
			position: absolute;
			top: 100%;
			left: 0;
			width: 100%;
			margin-top: 0;
			transform: none;
			box-shadow: 0 10px 20px rgba(0,0,0,0.1);
			border: none;
			border-top: 1px solid #eee;
			border-radius: 0 0 12px 12px;
			display: none;
			box-sizing: border-box;
			visibility: visible;
			opacity: 1;
		}
		.dropdown.is-active > .dropdown-content {
			display: block;
			visibility: visible;
			opacity: 1;
		}
		.dropdown-submenu .submenu-content {
			position: static;
			transform: none;
			box-shadow: none;
			border: none;
			margin-left: 1rem;
			border-left: 2px solid #eee;
			border-radius: 0;
			display: none;
			visibility: visible;
			opacity: 1;
		}
		.dropdown-submenu.is-active > .submenu-content {
			display: block;
		}
		.submenu-content-wide {
			display: block;
			min-width: 100%;
		}
