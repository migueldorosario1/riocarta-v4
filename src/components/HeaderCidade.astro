---
import { SITE_TITLE } from '../consts';
import logoImg from '../assets/logo-transparent.png';
import { Image } from 'astro:assets';
import vereadoresRj from '../data/vereadores_rj.json';

export interface Props {
	cityName: string;
	citySlug: string;
}

const { cityName, citySlug } = Astro.props;

const cidadeVereadores = (vereadoresRj.cidades ?? []).find(
	(c: any) => c.cidadeSlug === citySlug
);
const vereadores = (cidadeVereadores?.vereadores ?? []) as any[];
---

<header class="premium-header header-article">
	<nav class="navbar">
		<div class="header-left">
			<a href="/" class="logo-link">
				<Image src={logoImg} alt={SITE_TITLE} width={525} height={225} class="logo-img" />
			</a>
		</div>
		<div class="header-right">
			<div class="row-slogan">
				<span class="slogan-main">{cityName}</span>
				<span class="slogan-sub">Portal da Cidade • Rio Carta</span>
			</div>
			<div class="row-menu">
				<div class="nav-links">
					<div class="nav-item dropdown">
						<button class="dropbtn">Geografia <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg></button>
						<div class="dropdown-content">
							<a href={`/tags/historia-${citySlug}`} class="submenu-title" style="text-decoration: none; display: block;">História</a>
							<a href={`/tags/economia-${citySlug}`} class="submenu-title" style="text-decoration: none; display: block;">Economia</a>
							<a href={`/tags/mapa-${citySlug}`} class="submenu-title" style="text-decoration: none; display: block;">Mapa</a>
							<a href={`/tags/populacao-${citySlug}`} class="submenu-title" style="text-decoration: none; display: block;">População</a>
						</div>
					</div>

					<div class="nav-item dropdown">
<button class="dropbtn">Eleições <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg></button>
<div class="dropdown-content">
	<a href={`/tags/prefeitura-${citySlug}`} class="submenu-title" style="text-decoration: none; display: block;">Prefeito Atual</a>
	<div class="dropdown-submenu">
		<span class="submenu-title">Vereadores <span>▶</span></span>
		<div class="submenu-content" style="min-width:280px;">
			<a href={`/tags/camara-${citySlug}`} style="font-weight:700;border-bottom:1px solid #eee;margin-bottom:0.25rem;color:#0052D4;">Ver todos os vereadores →</a>
			{vereadores.map((v: any) => (
				<span style="display:block;padding:0.4rem 0.6rem;border-radius:6px;transition:background 0.15s;" onmouseover="this.style.background='#f0f2f5'" onmouseout="this.style.background='transparent'">
					<a href={`/tags/${v.slug}`} class="header-city-councilor-link">{v.nome}</a> <span style="background:#e6eaf0;color:#2c3e50;padding:0.1rem 0.4rem;border-radius:4px;font-size:0.75rem;font-weight:700;margin-left:0.25rem;">{v.partido}</span>
					<small style="display:block;font-size:0.75rem;color:#888;margin-top:0.15rem;">{v.votosNominaisValidos?.toLocaleString('pt-BR')} votos · {v.percentualMunicipio?.toFixed(1)}%</small>
				</span>
			))}
		</div>
	</div>
</div>
					</div>

					<div class="nav-item dropdown">
						<button class="dropbtn">Serviços <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg></button>
						<div class="dropdown-content">
							<div class="dropdown-submenu">
								<span class="submenu-title">Telefones Úteis <span>▶</span></span>
								<div class="submenu-content">
									<a href={`/tags/saude-${citySlug}`}>Posto de Saúde</a>
									<a href={`/tags/eletrica-${citySlug}`}>Companhia Elétrica</a>
									<a href={`/tags/assistencia-${citySlug}`}>Assistência Social</a>
									<a href={`/tags/imprensa-${citySlug}`}>Assessoria de Imprensa</a>
									<a href={`/tags/delegacia-${citySlug}`}>Delegacia de Polícia</a>
								</div>
							</div>
							<div class="dropdown-submenu">
								<span class="submenu-title">Lazer <span>▶</span></span>
								<div class="submenu-content">
									<a href={`/tags/bares-${citySlug}`}>Bares da Cidade</a>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
			<div class="row-social">
				<div class="social-links-header">
					<a href="/" title="Voltar ao Rio Carta" style="display: flex; align-items: center; gap: 0.5rem; font-weight: 600; text-decoration: none; font-size: 0.95rem; background: #f0f2f5; padding: 0.5rem 1rem; border-radius: 20px;">
						<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
						Voltar ao portal principal
					</a>
				</div>
			</div>
		</div>
	</nav>
</header>

<style>
	@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@800&family=Lora:ital,wght@1,500&family=Outfit:wght@500;600&display=swap');

	.premium-header {
		position: relative;
		top: 0;
		z-index: 1000;
		background: rgba(255, 255, 255, 0.95);
		backdrop-filter: blur(16px);
		border-bottom: 1px solid rgba(0, 0, 0, 0.05);
		padding: 0.75rem 2rem;
		box-shadow: 0 4px 30px rgba(0, 0, 0, 0.03);
	}

	.navbar {
		display: grid;
		grid-template-columns: auto 1fr;
		align-items: stretch;
		gap: 1.5rem;
		max-width: 1400px;
		margin: 0 auto;
	}

	.header-left {
		display: flex;
		align-items: stretch;
	}

	.logo-link {
		display: flex;
		align-items: center;
		justify-content: center;
		height: 100%;
		min-height: 90px;
		overflow: hidden;
		position: relative;
		flex-shrink: 0;
	}

	.logo-img {
		height: 100%;
		width: auto;
		max-width: 210px;
		object-fit: contain;
	}

	.header-right {
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 0.5rem;
		padding-left: 1.5rem;
		border-left: 3px solid #eee;
		min-height: 90px;
	}

	.row-slogan {
		display: flex;
		flex-direction: column;
		gap: 0.1rem;
	}

	.slogan-main {
		font-family: 'Montserrat', sans-serif;
		font-size: 1.25rem;
		font-weight: 800;
		color: #111;
		letter-spacing: -0.5px;
		text-transform: uppercase;
		line-height: 1.15;
	}

	.slogan-sub {
		font-family: 'Lora', serif;
		font-size: 1.05rem;
		font-style: italic;
		color: #0052D4;
		font-weight: 500;
	}

	.row-menu {
		display: flex;
		align-items: center;
	}

	.row-social {
		display: flex;
		align-items: center;
		margin-top: 0.25rem;
	}

	.nav-links {
		display: flex;
		align-items: center;
		gap: 2rem;
	}

	.nav-links :global(a) {
		font-family: 'Outfit', sans-serif;
		text-decoration: none;
		color: #333;
		font-weight: 600;
		font-size: 1.25rem;
		transition: color 0.2s;
		padding: 0.5rem 0;
		border-bottom: 2px solid transparent;
	}

	.nav-links :global(a:hover) {
		color: #0052D4;
	}

	.social-links-header {
		display: flex;
		gap: 1.25rem;
		align-items: center;
	}

	.social-links-header a {
		color: #555;
		transition: color 0.2s, transform 0.2s;
	}

	.social-links-header a:hover {
		color: #0052D4;
		transform: translateY(-2px);
	}

	/* Dropdown Core */
	.nav-item {
		position: relative;
	}

	.dropbtn {
		font-family: 'Outfit', sans-serif;
		background: none;
		border: none;
		font-size: 1.25rem;
		font-weight: 600;
		color: #333;
		cursor: pointer;
		display: flex;
		align-items: center;
		gap: 0.3rem;
		padding: 0.5rem 0;
		transition: color 0.2s;
	}

	.dropbtn:hover {
		color: #0052D4;
	}

	.dropdown-content {
		visibility: hidden;
		opacity: 0;
		position: absolute;
		top: 120%;
		left: 50%;
		transform: translateX(-50%) translateY(10px);
		background: white;
		min-width: 240px;
		border-radius: 12px;
		box-shadow: 0 10px 40px rgba(0,0,0,0.1);
		padding: 0.5rem;
		transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
	}

	@media (min-width: 769px) {
		.dropdown:hover .dropdown-content {
			visibility: visible;
			opacity: 1;
			transform: translateX(-50%) translateY(0);
		}
	}

	/* Submenu Core */
	.header-city-councilor-link {
		color: #111;
		font-weight: 700;
		text-decoration: none;
		display: inline-block;
		margin-right: 0.25rem;
		transition: color 0.15s ease;
	}
	.header-city-councilor-link:hover {
		color: #0052D4;
	}

	.dropdown-submenu {
		position: relative;
		padding: 0.2rem;
	}

	.submenu-title {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0.8rem 1rem;
		color: #444;
		font-weight: 500;
		cursor: pointer;
		border-radius: 8px;
		transition: background 0.2s;
	}

	.submenu-title span {
		font-size: 0.7em;
		color: #aaa;
	}

	@media (min-width: 769px) {
		.dropdown-submenu:hover .submenu-title {
			background: #f4f7fb;
			color: #0052D4;
		}
	}

	.submenu-content {
		visibility: hidden;
		opacity: 0;
		position: absolute;
		top: 0;
		left: 100%;
		margin-left: 0.5rem;
		background: white;
		min-width: 200px;
		max-height: 70vh;
		overflow-y: auto;
		border-radius: 12px;
		box-shadow: 0 10px 40px rgba(0,0,0,0.1);
		padding: 0.5rem;
		transform: translateX(10px);
		transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
		z-index: 100;
	}

	@media (min-width: 769px) {
		.dropdown-submenu:hover .submenu-content {
			visibility: visible;
			opacity: 1;
			transform: translateX(0);
		}
	}

	.submenu-content a {
		display: block;
		padding: 0.7rem 1rem;
		color: #555;
		text-decoration: none;
		border-radius: 6px;
		font-size: 0.95rem;
		transition: all 0.2s;
	}

	.submenu-content a:hover {
		background: #f4f7fb;
		color: #0052D4;
		padding-left: 1.2rem;
	}

	/* Mobile Responsiveness */
	@media (max-width: 768px) {
		.premium-header {
			padding: 0.5rem;
		}
		.header-article {
			position: relative;
		}
		.navbar {
			grid-template-columns: 1fr;
			gap: 0.5rem;
		}
		.header-left {
			justify-content: center;
		}
		.logo-link {
			min-height: 55px;
			width: 170px;
			height: auto;
		}
		.logo-img {
			max-width: 170px;
		}
		.header-right {
			border-left: none;
			border-top: 1px solid #eee;
			padding-left: 0;
			padding-top: 0.5rem;
			min-height: auto;
			align-items: center;
		}
		.row-slogan {
			align-items: center;
			text-align: center;
		}
		.slogan-main {
			font-size: 1.25rem;
		}
		.slogan-sub {
			font-size: 1.05rem;
		}
		.row-menu {
			width: 100%;
			justify-content: center;
		}
		.nav-links {
			flex-wrap: wrap;
			justify-content: center;
			gap: 0.5rem;
		}
		.dropbtn {
			font-size: 1.05rem;
			padding: 0.3rem 0;
		}
		.row-social {
			margin-top: 0.5rem;
			padding-bottom: 0.5rem;
		}
		.nav-item {
			position: static;
		}
		.dropdown-content {
			position: absolute;
			top: 100%;
			left: 0;
			width: 100%;
			margin-top: 0;
			transform: none;
			box-shadow: 0 10px 20px rgba(0,0,0,0.1);
			border: none;
			border-top: 1px solid #eee;
			border-radius: 0 0 12px 12px;
			display: none;
			box-sizing: border-box;
			visibility: visible;
			opacity: 1;
		}
		.dropdown.is-active > .dropdown-content {
			display: block;
			visibility: visible;
			opacity: 1;
		}
		.dropdown-submenu .submenu-content {
			position: static;
			transform: none;
			box-shadow: none;
			border: none;
			margin-left: 1rem;
			border-left: 2px solid #eee;
			border-radius: 0;
			display: none;
			visibility: visible;
			opacity: 1;
		}
		.dropdown-submenu.is-active > .submenu-content {
			display: block;
		}
	}
</style>

<script>
	const dropdowns = document.querySelectorAll('.dropdown');
	dropdowns.forEach(dropdown => {
		const btn = dropdown.querySelector('.dropbtn');
		if (!btn) return;
		btn.addEventListener('click', (e) => {
			if (window.innerWidth <= 768) {
				const isAnchor = e.target.tagName === 'A' || e.target.closest('a');
				if (!isAnchor) {
					e.preventDefault();
					dropdowns.forEach(d => {
					    if (d !== dropdown) d.classList.remove('is-active');
					});
					dropdown.classList.toggle('is-active');
				}
			}
		});
	});

	const submenus = document.querySelectorAll('.dropdown-submenu');
	submenus.forEach(submenu => {
		const title = submenu.querySelector('.submenu-title');
		if (!title) return;
		title.addEventListener('click', (e) => {
			if (window.innerWidth <= 768) {
				const isAnchor = e.target.tagName === 'A' || e.target.closest('a');
				if (!isAnchor) {
					e.preventDefault();
					const parent = submenu.closest('.dropdown-content');
					if (parent) {
					    parent.querySelectorAll('.dropdown-submenu').forEach(s => {
					        if (s !== submenu) s.classList.remove('is-active');
					    });
					}
					submenu.classList.toggle('is-active');
				}
			}
		});
	});

	document.addEventListener('click', (e) => {
		if (window.innerWidth <= 768) {
			const isDropdownClick = e.target.closest('.dropdown');
			if (!isDropdownClick) {
				document.querySelectorAll('.dropdown.is-active').forEach(d => {
					d.classList.remove('is-active');
				});
			}
		}
	});
</script>
