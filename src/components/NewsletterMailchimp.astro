---
// NewsletterMailchimp.astro - Componente premium de inscrição na newsletter do Rio Carta (Mailchimp)
---

<div class="newsletter-card">
    <div class="newsletter-glow"></div>
    <div class="newsletter-content">
        <div class="newsletter-header">
            <span class="newsletter-badge">Exclusivo</span>
            <h2>Receba a Cesta Premium do Rio Carta</h2>
            <p>Inscreva-se na nossa newsletter diária e receba as análises mais profundas e independentes do Rio de Janeiro direto na sua caixa de entrada.</p>
        </div>

        <!-- Formulário Mailchimp -->
        <form 
            action="https://riocarta.us21.list-manage.com/subscribe/post?u=5a720dc5ff5cf038318df2c5e&amp;id=d824d55ea1" 
            method="post" 
            id="mc-embedded-subscribe-form" 
            name="mc-embedded-subscribe-form" 
            class="newsletter-form validate" 
            target="_blank" 
            novalidate
        >
            <div class="input-group">
                <input 
                    type="email" 
                    name="EMAIL" 
                    class="email-input required email" 
                    id="mce-EMAIL" 
                    placeholder="Seu melhor e-mail..." 
                    required 
                />
                <!-- campo anti-bot do mailchimp -->
                <div style="position: absolute; left: -5000px;" aria-hidden="true">
                    <input type="text" name="b_5a720dc5ff5cf038318df2c5e_d824d55ea1" tabindex="-1" value="" />
                </div>
                <button type="submit" name="subscribe" id="mc-embedded-subscribe" class="subscribe-button">
                    <span>Inscrever</span>
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="22" y1="2" x2="11" y2="13"></line>
                        <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
                    </svg>
                </button>
            </div>
            <p class="privacy-note">Respeitamos sua privacidade. Cancele a qualquer momento com um clique.</p>
        </form>
    </div>
</div>

<style>
.newsletter-card {
    position: relative;
    margin: 4em auto 2em auto;
    padding: 2.5rem;
    background: linear-gradient(135deg, #1e293b, #0f172a);
    color: #f8fafc;
    border-radius: 16px;
    box-shadow: 0 10px 30px -10px rgba(15, 23, 42, 0.3);
    overflow: hidden;
    max-width: 720px;
    border: 1px solid rgba(255, 255, 255, 0.08);
}

.newsletter-glow {
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, rgba(99, 102, 241, 0.15) 0%, transparent 60%);
    pointer-events: none;
    z-index: 1;
}

.newsletter-content {
    position: relative;
    z-index: 2;
}

.newsletter-badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: rgba(99, 102, 241, 0.2);
    color: #a5b4fc;
    border-radius: 9999px;
    margin-bottom: 1rem;
    border: 1px solid rgba(99, 102, 241, 0.3);
}

.newsletter-header h2 {
    font-size: 1.85rem;
    font-weight: 800;
    margin: 0 0 0.75rem 0;
    background: linear-gradient(to right, #f8fafc, #cbd5e1);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    letter-spacing: -0.02em;
}

.newsletter-header p {
    font-size: 0.95rem;
    line-height: 1.6;
    color: #94a3b8;
    margin-bottom: 2rem;
}

.newsletter-form {
    width: 100%;
}

.input-group {
    display: flex;
    gap: 0.75rem;
    background: rgba(15, 23, 42, 0.6);
    padding: 0.35rem;
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: inset 0 2px 4px rgba(0, 0, 0, 0.2);
    transition: all 0.3s ease;
}

.input-group:focus-within {
    border-color: rgba(99, 102, 241, 0.5);
    box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.15), inset 0 2px 4px rgba(0, 0, 0, 0.2);
}

.email-input {
    flex: 1;
    background: transparent;
    border: none;
    padding: 0.75rem 1rem;
    color: #f8fafc;
    font-size: 1rem;
    font-family: inherit;
    outline: none;
}

.email-input::placeholder {
    color: #475569;
}

.subscribe-button {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: linear-gradient(135deg, #4f46e5, #4338ca);
    color: white;
    border: none;
    padding: 0.75rem 1.5rem;
    font-size: 0.95rem;
    font-weight: 600;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s ease;
}

.subscribe-button:hover {
    transform: translateY(-1px);
    background: linear-gradient(135deg, #6366f1, #4f46e5);
    box-shadow: 0 4px 12px rgba(79, 70, 229, 0.3);
}

.subscribe-button:active {
    transform: translateY(0);
}

.privacy-note {
    font-size: 0.75rem;
    color: #475569;
    margin: 0.75rem 0 0 0.5rem;
}

@media (max-width: 600px) {
    .newsletter-card {
        padding: 1.75rem;
    }
    .input-group {
        flex-direction: column;
        background: transparent;
        border: none;
        padding: 0;
        box-shadow: none;
        gap: 0.75rem;
    }
    .email-input {
        background: rgba(15, 23, 42, 0.6);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 8px;
        width: 100%;
        padding: 0.85rem 1rem;
    }
    .subscribe-button {
        width: 100%;
        justify-content: center;
        padding: 0.85rem 1.5rem;
    }
}
</style>
