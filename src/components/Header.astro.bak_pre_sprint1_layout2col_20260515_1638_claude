<style>
	@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@800&family=Lora:ital,wght@1,500&family=Outfit:wght@500;600&display=swap');

	.premium-header {
		position: sticky;
		top: 0;
		z-index: 1000;
		background: rgba(255, 255, 255, 0.95);
		backdrop-filter: blur(16px);
		border-bottom: 1px solid rgba(0, 0, 0, 0.05);
		padding: 0.5rem 2rem;
		box-shadow: 0 4px 30px rgba(0, 0, 0, 0.03);
	}
	
	.navbar {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1200px;
		margin: 0 auto;
		padding: 0.5rem 0;
	}

	.brand {
		display: flex;
		align-items: center;
		gap: 1.5rem;
	}

	.logo-link {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 480px;
		height: 188px;
		overflow: hidden;
		position: relative;
		margin-right: 15px;
		flex-shrink: 0;
	}

	.logo-img {
		height: 100%;
		width: 100%;
		object-fit: contain;
	}

	.slogan {
		display: flex;
		flex-direction: column;
		border-left: 3px solid #eee;
		padding-left: 1.5rem;
		gap: 0.1rem;
	}

	.slogan-main {
		font-family: 'Montserrat', sans-serif;
		font-size: 1.3rem;
		font-weight: 800;
		color: #111;
		letter-spacing: -0.5px;
		text-transform: uppercase;
	}

	.slogan-sub {
		font-family: 'Lora', serif;
		font-size: 1.05rem;
		font-style: italic;
		color: #d32f2f;
		font-weight: 500;
	}

	.badge {
		font-size: 0.6rem;
		background: #ff4757;
		color: white;
		padding: 2px 6px;
		border-radius: 10px;
		vertical-align: super;
		margin-left: 4px;
	}

	.nav-links {
		display: flex;
		align-items: center;
		gap: 2rem;
	}

	.nav-links :global(a) {
		font-family: 'Outfit', sans-serif;
		text-decoration: none;
		color: #333;
		font-weight: 600;
		font-size: 1.1rem;
		transition: color 0.2s;
		padding: 0.5rem 0;
		border-bottom: 2px solid transparent;
	}
	
	.nav-links :global(a:hover) {
		color: #0052D4;
	}
	
	.nav-links :global(a.active) {
		color: #0052D4;
		border-bottom: 2px solid #0052D4;
	}

	.social-links-header {
		display: flex;
		gap: 1rem;
		align-items: center;
		margin-left: 1rem;
		padding-left: 1rem;
		border-left: 1px solid #eee;
	}

	.social-links-header a {
		color: #555;
		transition: color 0.2s, transform 0.2s;
		display: flex;
	}

	.social-links-header a:hover {
		color: #0052D4;
		transform: translateY(-2px);
	}

	/* Dropdown Core */
	.nav-item {
		position: relative;
	}

	.dropbtn {
		font-family: 'Outfit', sans-serif;
		background: none;
		border: none;
		font-size: 1.1rem;
		font-weight: 600;
		color: #333;
		cursor: pointer;
		display: flex;
		align-items: center;
		gap: 0.3rem;
		padding: 0.5rem 0;
		transition: color 0.2s;
	}

	.dropbtn:hover {
		color: #0052D4;
	}

	.dropdown-content {
		visibility: hidden;
		opacity: 0;
		position: absolute;
		top: 120%;
		left: 50%;
		transform: translateX(-50%) translateY(10px);
		background: white;
		min-width: 240px;
		border-radius: 12px;
		box-shadow: 0 10px 40px rgba(0,0,0,0.1);
		padding: 0.5rem;
		transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
	}

	/* Dropdown Hover apenas para Desktop */
	@media (min-width: 769px) {
		.dropdown:hover .dropdown-content {
			visibility: visible;
			opacity: 1;
			transform: translateX(-50%) translateY(0);
		}
	}

	/* Submenu Core */
	.dropdown-submenu {
		position: relative;
		padding: 0.2rem;
	}

	.submenu-title {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0.8rem 1rem;
		color: #444;
		font-weight: 500;
		cursor: pointer;
		border-radius: 8px;
		transition: background 0.2s;
	}

	.submenu-title span {
		font-size: 0.7em;
		color: #aaa;
	}

	@media (min-width: 769px) {
		.dropdown-submenu:hover .submenu-title {
			background: #f4f7fb;
			color: #0052D4;
		}
	}

	.submenu-content {
		visibility: hidden;
		opacity: 0;
		position: absolute;
		top: 0;
		left: 100%;
		margin-left: 0.5rem;
		background: white;
		min-width: 200px;
		max-height: 70vh;
		overflow-y: auto;
		border-radius: 12px;
		box-shadow: 0 10px 40px rgba(0,0,0,0.1);
		padding: 0.5rem;
		transform: translateX(10px);
		transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
		z-index: 100;
	}

	.submenu-content-wide {
		min-width: min(720px, 70vw);
		display: grid;
		grid-template-columns: repeat(2, minmax(220px, 1fr));
		gap: 0.35rem 1rem;
	}

	.submenu-section {
		padding: 0.35rem;
		border-bottom: 1px solid #f0f2f5;
	}

	.submenu-section-title {
		font-weight: 800;
		color: #111 !important;
		background: #f7f9fc;
	}

	@media (min-width: 769px) {
		.dropdown-submenu:hover .submenu-content {
			visibility: visible;
			opacity: 1;
			transform: translateX(0);
		}
	}

	.submenu-content a {
		display: block;
		padding: 0.7rem 1rem;
		color: #555;
		text-decoration: none;
		border-radius: 6px;
		font-size: 0.95rem;
		transition: all 0.2s;
	}

	.submenu-content a:hover {
		background: #f4f7fb;
		color: #0052D4;
		padding-left: 1.2rem;
	}

	/* Mobile Responsiveness */
	@media (max-width: 768px) {
		.premium-header {
			padding: 0.5rem;
		}
		.header-home {
			position: relative; /* Not sticky on home so it doesn't take up space */
		}
		.header-article {
			position: sticky;
			top: 0;
			padding: 0.2rem 0.5rem;
		}
		.navbar {
			flex-direction: column;
			gap: 0.5rem;
		}
		.header-article .navbar {
			flex-direction: row;
			flex-wrap: wrap;
			justify-content: space-between;
			align-items: center;
		}
		.brand {
			flex-direction: column;
			text-align: center;
			gap: 0.2rem;
		}
		.header-article .brand {
			flex-direction: row;
		}
		.logo-link {
			margin-right: 0;
			width: 200px;
			height: auto;
			max-height: 80px;
		}
		.header-article .logo-link {
			width: 120px;
			max-height: 40px;
		}
		.slogan {
			display: none; /* Hide title and name on mobile */
		}
		.nav-links {
			flex-wrap: wrap;
			justify-content: center;
			gap: 0.5rem;
		}
		.header-article .nav-links {
			gap: 0.3rem;
		}
		.header-article .dropbtn {
			font-size: 0.9rem;
			padding: 0.2rem 0;
		}
		.social-links-header {
			display: none; /* Removed from mobile header as requested */
		}
		.header-article .social-links-header {
			display: none; /* Ensure it's hidden on articles too */
		}
		.nav-item {
			position: static;
		}
		.dropdown-content {
			position: absolute;
			top: 100%;
			left: 0;
			width: 100%;
			margin-top: 0;
			transform: none;
			box-shadow: 0 10px 20px rgba(0,0,0,0.1);
			border: none;
			border-top: 1px solid #eee;
			border-radius: 0 0 12px 12px;
			display: none;
			box-sizing: border-box;
			visibility: visible;
			opacity: 1;
		}
		.dropdown.is-active > .dropdown-content {
			display: block;
			visibility: visible;
			opacity: 1;
		}
		.dropdown-submenu .submenu-content {
			position: static;
			transform: none;
			box-shadow: none;
			border: none;
			margin-left: 1rem;
			border-left: 2px solid #eee;
			border-radius: 0;
			display: none;
			visibility: visible;
			opacity: 1;
		}
		.dropdown-submenu.is-active > .submenu-content {
			display: block;
		}
		.submenu-content-wide {
			display: block;
			min-width: 100%;
		}
	}
</style>

<script>
	const dropdowns = document.querySelectorAll('.dropdown');
	dropdowns.forEach(dropdown => {
		const btn = dropdown.querySelector('.dropbtn');
		if (!btn) return;
		btn.addEventListener('click', (e) => {
			if (window.innerWidth <= 768) {
				const isAnchor = e.target.tagName === 'A' || e.target.closest('a');
				if (!isAnchor) {
					e.preventDefault();
					// Fecha os outros dropdowns principais
					dropdowns.forEach(d => {
					    if (d !== dropdown) d.classList.remove('is-active');
					});
					dropdown.classList.toggle('is-active');
				}
			}
		});
	});

	const submenus = document.querySelectorAll('.dropdown-submenu');
	submenus.forEach(submenu => {
		const title = submenu.querySelector('.submenu-title');
		if (!title) return;
		title.addEventListener('click', (e) => {
			if (window.innerWidth <= 768) {
				const isAnchor = e.target.tagName === 'A' || e.target.closest('a');
				if (!isAnchor) {
					e.preventDefault();
					// Fecha os outros submenus dentro do mesmo dropdown
					const parent = submenu.closest('.dropdown-content');
					if (parent) {
					    parent.querySelectorAll('.dropdown-submenu').forEach(s => {
					        if (s !== submenu) s.classList.remove('is-active');
					    });
					}
					submenu.classList.toggle('is-active');
				}
			}
		});
	});

	// Fechar ao clicar fora no mobile
	document.addEventListener('click', (e) => {
		if (window.innerWidth <= 768) {
			const isDropdownClick = e.target.closest('.dropdown');
			if (!isDropdownClick) {
				document.querySelectorAll('.dropdown.is-active').forEach(d => {
					d.classList.remove('is-active');
				});
			}
		}
	});
</script>
