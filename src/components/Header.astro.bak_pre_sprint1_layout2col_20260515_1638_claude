---
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import HeaderLink from './HeaderLink.astro';
import logoImg from '../assets/logo-transparent.png';
import { Image } from 'astro:assets';
import { rioZones, rjRegions } from '../data/rjTaxonomy';

const pathname = Astro.url.pathname;
const isHome = pathname === '/' || pathname === '/index.html';
---

<header class={`premium-header ${isHome ? 'header-home' : 'header-article'}`}>
	<nav class="navbar">
		<div class="brand">
			<a href="/" class="logo-link">
				<Image src={logoImg} alt={SITE_TITLE} width={525} height={225} class="logo-img" />
			</a>
			<div class="slogan">
				<span class="slogan-main">Portal de Notícias do Rio de Janeiro</span>
				<span class="slogan-sub">por Miguel do Rosário</span>
			</div>
		</div>
		<div class="nav-links">
			<div class="nav-item dropdown">
				<button class="dropbtn">Início <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg></button>
				<div class="dropdown-content">
					<a href="/" class="submenu-title" style="text-decoration: none; display: block; font-weight: bold;">Capa do Site</a>
					<a href="/quem-somos" class="submenu-title" style="text-decoration: none; display: block;">Quem Somos</a>
					<a href="/editorial" class="submenu-title" style="text-decoration: none; display: block;">Editorial</a>
					<div class="dropdown-submenu">
						<span class="submenu-title">Histórico <span>▶</span></span>
						<div class="submenu-content">
							<a href="/historico/2026">2026</a>
							<a href="/historico/2025">2025</a>
							<a href="/historico/2024">2024</a>
							<a href="/historico/2023">2023</a>
