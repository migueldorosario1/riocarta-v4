					</div>
				</div>
			</div>
			
			<div class="nav-item dropdown">
				<button class="dropbtn">Rio <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg></button>
				<div class="dropdown-content">
					<div class="dropdown-submenu">
						<span class="submenu-title">Rio Capital: zonas e bairros <span>▶</span></span>
						<div class="submenu-content submenu-content-wide">
							{rioZones.map((zone) => (
								<div class="submenu-section">
									<a href={`/tags/${zone.slug}`} class="submenu-section-title">{zone.label}</a>
									{zone.items.map((item) => <a href={`/tags/${item.slug}`}>{item.label}</a>)}
								</div>
							))}
						</div>
					</div>
					<div class="dropdown-submenu">
						<span class="submenu-title">Cidades por região <span>▶</span></span>
						<div class="submenu-content submenu-content-wide">
							{rjRegions.map((region) => (
								<div class="submenu-section">
									<a href={`/tags/${region.slug}`} class="submenu-section-title">{region.label}</a>
									{region.items.map((item) => <a href={`/tags/${item.slug}`}>{item.label}</a>)}
